{
  "name": "@saasly/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "verify:imap-sync": "tsx src/scripts/verify-imap-sync.ts",
    "send-test-mail": "tsx src/scripts/send-test-mail.ts",
    "verify:send": "tsx src/scripts/verify-send.ts",
    "verify:calendar": "tsx src/scripts/verify-calendar.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1001.0",
    "@saasly/database": "workspace:*",
    "@saasly/emails": "workspace:*",
    "@saasly/shared": "workspace:*",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "googleapis": "^173.0.0",
    "imapflow": "^1.4.7",
    "ioredis": "^5.11.1",
    "mailparser": "^3.9.14",
    "node-ical": "^0.26.1",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "tsdav": "^2.3.1",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@saasly/config": "workspace:*",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.23.0"
  }
}

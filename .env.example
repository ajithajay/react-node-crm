# Copy to .env for local development:  cp .env.example .env
# docker compose (run from repo root) and the apps both read this file.

# --- Node ---
NODE_ENV=development

# --- API ---
API_PORT=4000

# --- Web ---
WEB_PORT=3000

# --- Postgres (docker container + app connection) ---
POSTGRES_USER=saasly
POSTGRES_PASSWORD=saasly
POSTGRES_DB=saasly
POSTGRES_PORT=5432
DATABASE_URL=postgres://saasly:saasly@localhost:5432/saasly

# --- Redis (BullMQ) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Mailpit (dev SMTP sink; UI at http://localhost:8025) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
EMAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM="Saasly CRM <no-reply@saasly.local>"

# --- Connected accounts: email + calendar sync ---
# GreenMail dev mailbox (docker compose service `greenmail`): SMTP 3025 / IMAP 3143 (plaintext),
# IMAPS 3993 (self-signed), REST API 8080. Connect it in Settings → Accounts with TLS off.
GREENMAIL_SMTP_PORT=3025
GREENMAIL_IMAP_PORT=3143
GREENMAIL_IMAPS_PORT=3993
GREENMAIL_API_PORT=8080
MESSAGING_SYNC_ENABLED=true
CALENDAR_SYNC_ENABLED=true
MESSAGING_LIST_FETCH_CRON=*/5 * * * *
MESSAGING_IMPORT_CRON=* * * * *
MESSAGING_IMPORT_MAX_PER_MIN=400
# Allow IMAP/SMTP/CalDAV to private/loopback IPs (set false for stricter SSRF posture in prod).
OUTBOUND_HTTP_SAFE_MODE_ENABLED=true
# Gmail + Google Calendar OAuth (leave blank to keep Google connect disabled). Redirect URI must
# match the one registered in your Google Cloud OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://api.lvh.me:4000/oauth/google/callback

# --- MinIO (S3-compatible; console at http://localhost:9001) ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=saasly
MINIO_ROOT_PASSWORD=saasly-secret
# STORAGE_TYPE=local uses LOCAL_STORAGE_DIR (default ./.storage) instead of S3/MinIO.
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=saasly
S3_SECRET_KEY=saasly-secret
S3_BUCKET=saasly

# --- Webhooks ---
# Blocks loopback/link-local/private-range delivery targets by default (SSRF guard). Set to true
# only for local dev testing against a receiver on localhost or a private network.
WEBHOOK_ALLOW_PRIVATE_TARGETS=true
# Delivery retries: attempts before giving up, and the base exponential backoff delay (ms) between them.
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_BACKOFF_MS=5000

# --- Public REST API (/api/v1, API-key auth only) ---
# Workspace-level rate limit (not per API key) — all keys in a workspace share this budget.
PUBLIC_API_RATE_LIMIT_PER_MIN=60

# --- Domains / URLs (subdomain multi-tenancy) ---
# lvh.me and *.lvh.me resolve to 127.0.0.1 — great for local subdomain testing.
APP_BASE_DOMAIN=lvh.me
FRONTEND_URL=http://app.lvh.me:3000

# --- Web (Vite; exposed to the browser) ---
# VITE_API_URL is left unset — the frontend calls the API on the current page's own
# hostname (Host header drives workspace resolution), just on VITE_API_PORT.
# VITE_API_URL=http://api.lvh.me:4000   # uncomment to force a fixed API host instead
VITE_API_PORT=4000

# --- Auth (used from Phase 3) ---
JWT_SECRET=dev-only-change-me

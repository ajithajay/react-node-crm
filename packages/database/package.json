{
  "name": "@saasly/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "verify:phase2": "tsx src/scripts/verify-phase2.ts",
    "verify:datamodel": "tsx src/scripts/verify-datamodel.ts"
  },
  "dependencies": {
    "@saasly/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@saasly/config": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0"
  }
}
